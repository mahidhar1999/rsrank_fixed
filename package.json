{
  "name": "rsrank",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev":           "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend":   "cd backend && .venv/Scripts/activate && uvicorn app.main:app --reload --port 8000",
    "dev:frontend":  "cd frontend && npm run dev",
    "install:all":   "npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend":  "cd backend && python -m venv .venv && .venv/Scripts/pip install -r requirements.txt",
    "setup:db":      "cd backend && .venv/Scripts/python scripts/setup_db.py",
    "pipeline:daily":   "cd backend && .venv/Scripts/python pipeline/daily.py",
    "pipeline:monthly": "cd backend && .venv/Scripts/python pipeline/monthly.py",
    "build":         "cd frontend && npm run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
